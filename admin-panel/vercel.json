{
  "name": "jobrobots-admin",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    { "handle": "filesystem" },   // ✅ serve real files first
    { "src": "/.*", "dest": "/index.html" }  // fallback for React routing
  ]
}
